# Server
PORT=8080
NODE_ENV=development

# DB
SQLITE_PATH=./data/healthcare.db

# Auth
# 32바이트 랜덤 hex 권장: openssl rand -hex 32
JWT_SECRET=change-me-in-production-please
JWT_EXPIRES_IN=12h
# 데모 사용자 비밀번호 (seed.js가 사용). 미설정 시 'demo1234' 사용.
# 외부 노출 환경에선 반드시 강한 값으로 설정.
DEMO_PASSWORD=demo1234

# 허용된 origin (콤마 구분). 미설정 시 모든 origin 허용 (dev only).
# 예: ALLOWED_ORIGINS=http://localhost:8080,http://13.209.81.179:8080
ALLOWED_ORIGINS=

# MQTT (laptop backend subscribes; Pi publishes)
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_TOPIC_PREFIX=healthcare/v1

# Cron
MORNING_JOB_CRON=30 7 * * *
TIMEZONE=Asia/Seoul

# Fitbit OAuth (optional — leave blank to use simulator only)
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=
FITBIT_REDIRECT_URI=http://13.209.81.179:8080/api/v1/fitbit/callback
