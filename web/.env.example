# React 빌드(Vite) 환경변수 — Cognito 연동 (Cloud 단계)
# 실제 값은 `cdk deploy` 출력(CfnOutput)에서 복사:
#   UserPoolId       → VITE_COGNITO_USER_POOL_ID
#   UserPoolClientId → VITE_COGNITO_CLIENT_ID
#
# 사용:  cp web/.env.example web/.env  후 값 채우고  `npm run build:web`

VITE_COGNITO_USER_POOL_ID=ap-northeast-2_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# API Gateway 호출 base. CloudFront 멀티오리진이면 비워두면 됨(상대경로 /api/v1).
# API Gateway를 직접 호출할 경우에만 절대 URL 지정:
# VITE_API_BASE=https://xxxxxx.execute-api.ap-northeast-2.amazonaws.com/prod/api/v1
